# SQLite database file (the same data/app.db the main app uses).
# Accepts a `file:` URL or a bare path; an absolute path is recommended since
# the MCP server runs as a separate process with its own working directory.
DATABASE_URL=file:/absolute/path/to/liz-whiteboard/data/app.db

# Session token: copy from browser DevTools -> Application -> Cookies -> session_token
# after logging in to liz-whiteboard
LIZ_SESSION_TOKEN=

# Socket.IO URL of the running main app (write path only)
LIZ_SOCKET_URL=ws://localhost:3010
