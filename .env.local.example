# PostgreSQL connection (same DB as the main app — read-write access required)
DATABASE_URL=
DIRECT_DATABASE_URL=

# Session token: copy from browser DevTools -> Application -> Cookies -> session_token
# after logging in to liz-whiteboard
LIZ_SESSION_TOKEN=

# Socket.IO URL of the running main app (write path only)
LIZ_SOCKET_URL=ws://localhost:3010
